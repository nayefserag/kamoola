# Server
PORT=3001
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/kamoola

# CORS
CORS_ORIGIN=http://localhost:5173

# JWT Authentication
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRATION=7d

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Scraper Plugin URLs (optional overrides)
# ASURASCANS_BASE_URL=https://asuracomic.net
# MADARA_BASE_URL=https://manhuaplus.top
# MANGAKAKALOT_BASE_URL=https://mangakakalot.gg
# OLYMPUSTAFF_BASE_URL=https://olympustaff.com

# MangaDex languages (comma-separated, default: en,ar)
# MANGADEX_LANGUAGES=en,ar
